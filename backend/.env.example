# Variables de entorno del backend
# Copia este archivo a backend/.env y completa los valores

# Servidor
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=24h

# PostgreSQL – usado por Docker Compose (no cambiar en desarrollo local con Docker)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecommify
POSTGRES_USER=ecommify
POSTGRES_PASSWORD=ecommify_pass
POSTGRES_SSL=false

# PostgreSQL – alternativa con URL completa (Supabase, Render, etc.)
# POSTGRES_URL=postgresql://user:password@host:5432/dbname

# MongoDB – usado por Docker Compose (no cambiar en desarrollo local con Docker)
MONGODB_URI=mongodb://mongo:27017/ecommify

# MongoDB – alternativa Atlas
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ecommify?retryWrites=true&w=majority
